+# If the user toolchain supports IPO, we enable it for the app build.
+# Skip on Android: CMake's IPO probe uses -fuse-ld=gold, which NDK r26+ Clang
+# rejects ("invalid linker name"), so configure can fail or behave inconsistently.
+if(NOT ANDROID)
+  include(CheckIPOSupported)
+  check_ipo_supported(RESULT IPO_SUPPORT)
+  if (IPO_SUPPORT)
+    set(CMAKE_INTERPROCEDURAL_OPTIMIZATION TRUE)
+  endif()
 endif()
 
 set(BUILD_DIR ${PROJECT_BUILD_DIR})
